<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="leo" 
               params="default_antenna:=true
                       rockers_fixed:=true
                       footprint_link:=true
                       link_prefix:=''
                       joint_prefix:=''
                       imu_translation:='0.1256 -0.0628 -0.0786'
                       mecanum_wheels:=false">

    <xacro:macro name="rocker_link" params="name">
      <link name="${link_prefix}rocker_${name}_link">
        <inertial>
          <mass value="12.486"/>
          <origin xyz="0 0.02692 -0.13012"/>
          <inertia
            ixx="0.106416" ixy="-5.36157e-05" ixz="-0.000291723"
            iyy="1.05264"  iyz="0.00256032"
            izz="1.01952"/>
        </inertial>
        <visual>
          <geometry>
            <mesh filename="package://leo_description/models/Rocker.dae" scale="2.0 2.0 2.0"/>
          </geometry>
        </visual>
        <collision>
          <geometry>
            <mesh filename="package://leo_description/models/Rocker_outline.stl" scale="2.0 2.0 2.0"/>
          </geometry>
        </collision>
      </link>
    </xacro:macro>

    <xacro:macro name="wheel_link" params="name model"> 
      <link name="${link_prefix}wheel_${name}_link">
        <inertial>
          <mass value="2.55278"/>
          <origin xyz="0 0.060052 0"/>
          <inertia
            ixx="0.014076"  ixy="4.46263e-05" ixz="1.9893e-05"
            iyy="0.0169776" iyz="-7.49535e-05"
            izz="0.014076"/>
        </inertial>
        <visual>
          <geometry>
            <mesh filename="package://leo_description/models/Wheel${model}.dae" scale="2.0 2.0 2.0"/>
          </geometry>
        </visual>
        <collision>
          <origin xyz="0 0.0897 0" rpy="${pi/2} 0 0"/>
          <geometry>
            <cylinder radius="0.114" length="0.14"/>
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0.0897 0" rpy="${pi/2} 0 0"/>
          <geometry>
            <cylinder radius="0.125" length="0.08"/>
          </geometry>
        </collision>
        <collision>
          <geometry>
            <mesh filename="package://leo_description/models/Wheel_outline.stl" scale="2.0 2.0 2.0"/>
          </geometry>
        </collision>
      </link>
    </xacro:macro>

    <xacro:macro name="mecanum_wheel_link" params="name model"> 
      <link name="${link_prefix}wheel_${name}_link">
        <inertial>
          <mass value="6.04993"/>
          <origin xyz="0 -0.073704 0"/>
          <inertia
            ixx="0.0352008"  ixy="-2.91682e-05" ixz="1.152e-09"
            iyy="0.047556" iyz="2.052e-09"
            izz="0.0351828"/>
        </inertial>
        <visual>
          <geometry>
            <mesh filename="package://leo_description/models/WheelMecanum${model}.dae" scale="2.0 2.0 2.0"/>
          </geometry>
        </visual>
        <collision>
          <origin xyz="0 -0.0634 0" rpy="${pi/2} 0 0"/>
          <geometry>
            <cylinder radius="0.127" length="0.103"/>
          </geometry>
        </collision>
        <collision>
          <geometry>
            <mesh filename="package://leo_description/models/Mecanum_wheel_outline.stl" scale="2.0 2.0 2.0"/>
          </geometry>
        </collision>
      </link>
    </xacro:macro>

    <!-- LINKS -->
    <xacro:if value="${footprint_link}">
      <link name="${link_prefix}base_footprint"/>
    </xacro:if>

    <link name="${link_prefix}base_link">
      <inertial>
        <mass value="24.65"/>
        <origin xyz="-0.039324 0.023286 -0.063604"/>
        <inertia
          ixx="0.650" ixy="0.042372" ixz="-0.0319356"
          iyy="0.652" iyz="0.0080136"
          izz="1.133"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://leo_description/models/Chassis.dae" scale="2.0 2.0 2.0"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://leo_description/models/Chassis_outline.stl" scale="2.0 2.0 2.0"/>
        </geometry>
      </collision>
    </link>

    <xacro:rocker_link name="L"/>
    <xacro:rocker_link name="R"/>
    <xacro:if value="${mecanum_wheels}">
      <xacro:mecanum_wheel_link name="FL" model="B"/>
      <xacro:mecanum_wheel_link name="RL" model="A"/>
      <xacro:mecanum_wheel_link name="FR" model="A"/>
      <xacro:mecanum_wheel_link name="RR" model="B"/>
    </xacro:if>
    <xacro:unless value="${mecanum_wheels}">
      <xacro:wheel_link name="FL" model="A"/>
      <xacro:wheel_link name="RL" model="A"/>
      <xacro:wheel_link name="FR" model="B"/>
      <xacro:wheel_link name="RR" model="B"/>
    </xacro:unless>

    <xacro:if value="${default_antenna}">
      <link name="${link_prefix}antenna_link">
        <inertial>
          <mass value="0.011133"/>
          <origin xyz="0 0 0.057656"/>
          <inertia
            ixx="9.19044e-06" ixy="0" ixz="0"
            iyy="9.19044e-06" iyz="0"
            izz="4.8744e-07"/>
        </inertial>
        <visual>
          <geometry>
            <mesh filename="package://leo_description/models/Antenna.dae" scale="2.0 2.0 2.0"/>
          </geometry>
        </visual>
        <collision>
          <origin xyz="0 0 0.056"/>
          <geometry>
            <cylinder radius="0.011" length="0.112"/>
          </geometry>
        </collision>
      </link>
    </xacro:if>

    <link name="${link_prefix}camera_frame"/>
    <link name="${link_prefix}camera_optical_frame"/>
    <link name="${link_prefix}imu_frame"/>

    <!-- LiDAR link -->
    <link name="${link_prefix}lidar_link">
      <inertial>
        <mass value="0.17"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.001" ixy="0" ixz="0"
                 iyy="0.001" iyz="0"
                 izz="0.001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.035" length="0.04"/>
        </geometry>
        <material name="dark_grey">
          <color rgba="0.2 0.2 0.2 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.035" length="0.04"/>
        </geometry>
      </collision>
    </link>

    <!-- JOINTS -->

    <xacro:if value="${footprint_link}">
      <joint name="${joint_prefix}base_joint" type="fixed">
        <origin xyz="0 0 0.39566" rpy="0 0 0"/>
        <parent link="${link_prefix}base_footprint"/>
        <child link="${link_prefix}base_link"/>
      </joint>
    </xacro:if>

    <xacro:if value="${rockers_fixed}">
      <xacro:property name="rockers_joint_type" value="fixed"/>
    </xacro:if>
    <xacro:unless value="${rockers_fixed}">
      <xacro:property name="rockers_joint_type" value="revolute"/>
    </xacro:unless>

    <joint name="${joint_prefix}rocker_L_joint" type="${rockers_joint_type}">
      <origin xyz="0.00526 0.28334 -0.09462" rpy="0 0 ${pi}"/>
      <parent link="${link_prefix}base_link"/>
      <child link="${link_prefix}rocker_L_link"/>
      <axis xyz="0 1 0"/>
      <limit effort="100.0" lower="-0.24" upper="0.24" velocity="100.0"/>
      <dynamics friction="5.0" damping="15.0"/>
    </joint>

    <joint name="${joint_prefix}rocker_R_joint" type="${rockers_joint_type}">
      <origin xyz="0.00526 -0.28334 -0.09462" rpy="0 0 0"/>
      <parent link="${link_prefix}base_link"/>
      <child link="${link_prefix}rocker_R_link"/>
      <axis xyz="0 1 0"/>
      <limit effort="100.0" lower="-0.24" upper="0.24" velocity="100.0"/>
      <dynamics friction="5.0" damping="15.0"/> 
      <mimic joint="rocker_L_joint"/>
    </joint>

    <joint name="${joint_prefix}wheel_FL_joint" type="continuous">
      <xacro:if value="${mecanum_wheels}">
        <origin xyz="-0.30512 -0.01768 -0.17604" rpy="0 0 0"/>
      </xacro:if>
      <xacro:unless value="${mecanum_wheels}">
        <origin xyz="-0.30512 -0.16428 -0.17604" rpy="0 0 0"/>
      </xacro:unless>
      <parent link="${link_prefix}rocker_L_link"/>
      <child link="${link_prefix}wheel_FL_link"/>
      <axis xyz="0 -1 0"/>
      <limit effort="200.0" velocity="20.0"/>
      <dynamics friction="0.3" damping="0.3"/>
    </joint>

    <joint name="${joint_prefix}wheel_RL_joint" type="continuous">
      <xacro:if value="${mecanum_wheels}">
        <origin xyz="0.30512 -0.01768 -0.17604" rpy="0 0 0"/>
      </xacro:if>      
      <xacro:unless value="${mecanum_wheels}">
        <origin xyz="0.30512 -0.16428 -0.17604" rpy="0 0 0"/>
      </xacro:unless>
      <parent link="${link_prefix}rocker_L_link"/>
      <child link="${link_prefix}wheel_RL_link"/>
      <axis xyz="0 -1 0"/>
      <limit effort="200.0" velocity="20.0"/>
      <dynamics friction="0.3" damping="0.3"/>
    </joint>

    <joint name="${joint_prefix}wheel_FR_joint" type="continuous">
      <xacro:if value="${mecanum_wheels}">
        <origin xyz="0.30512 -0.01768 -0.17604" rpy="0 0 0"/>
      </xacro:if>
      <xacro:unless value="${mecanum_wheels}">
        <origin xyz="0.30512 -0.16428 -0.17604" rpy="0 0 0"/>
      </xacro:unless>
      <parent link="${link_prefix}rocker_R_link"/>
      <child link="${link_prefix}wheel_FR_link"/>
      <axis xyz="0 1 0"/>
      <limit effort="200.0" velocity="20.0"/>
      <dynamics friction="0.3" damping="0.3"/>
    </joint>

    <joint name="${joint_prefix}wheel_RR_joint" type="continuous">
      <xacro:if value="${mecanum_wheels}">
        <origin xyz="-0.30512 -0.01768 -0.17604" rpy="0 0 0"/>
      </xacro:if>
      <xacro:unless value="${mecanum_wheels}">
        <origin xyz="-0.30512 -0.16428 -0.17604" rpy="0 0 0"/>
      </xacro:unless>
      <parent link="${link_prefix}rocker_R_link"/>
      <child link="${link_prefix}wheel_RR_link"/>
      <axis xyz="0 1 0"/>
      <limit effort="200.0" velocity="20.0"/>
      <dynamics friction="0.3" damping="0.3"/> 
    </joint>

    <xacro:if value="${default_antenna}">
      <joint name="${joint_prefix}antenna_joint" type="fixed">
        <origin xyz="-0.0104 0.112 -0.013" rpy="0 0 0"/>
        <parent link="${link_prefix}base_link"/>
        <child link="${link_prefix}antenna_link"/>
      </joint>
    </xacro:if>

    <joint name="${joint_prefix}camera_joint" type="fixed">
      <origin xyz="0.1942 0 -0.0854" rpy="0 0.2094 0"/>
      <parent link="${link_prefix}base_link"/>
      <child link="${link_prefix}camera_frame"/>
    </joint>

    <joint name="${joint_prefix}camera_optical_joint" type="fixed">
      <origin xyz="0 0 0" rpy="-${pi/2} 0.0 -${pi/2}"/>
      <parent link="${link_prefix}camera_frame"/>
      <child link="${link_prefix}camera_optical_frame"/>
    </joint>

    <joint name="${joint_prefix}imu_joint" type="fixed">
      <origin xyz="${imu_translation}" rpy="0 0 0"/>
      <parent link="${link_prefix}base_link"/>
      <child link="${link_prefix}imu_frame"/>
    </joint>

    <!-- LiDAR joint - mounted on top of the robot -->
    <joint name="${joint_prefix}lidar_joint" type="fixed">
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <parent link="${link_prefix}base_link"/>
      <child link="${link_prefix}lidar_link"/>
    </joint>

  </xacro:macro>

  <!-- LEO GAZEBO -->

  <xacro:macro name="leo_gazebo"
               params="robot_ns:='''">

    <xacro:property name="link_prefix" value=""/>
    <xacro:if value="${robot_ns != '' and robot_ns != '/'}">
      <xacro:property name="link_prefix" value="${robot_ns}/"/>
    </xacro:if>

    <!-- base ODE properties -->
    <gazebo reference="${link_prefix}base_footprint">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
            <bullet>
              <friction>0.3</friction>
              <friction2>0.3</friction2>
              <rolling_friction>0.1</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo reference="${link_prefix}base_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
            <bullet>
              <friction>0.3</friction>
              <friction2>0.3</friction2>
              <rolling_friction>0.1</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <!-- rocker ODE properties -->
    <gazebo reference="${link_prefix}rocker_L_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
            <bullet>
              <friction>0.3</friction>
              <friction2>0.3</friction2>
              <rolling_friction>0.1</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo reference="${link_prefix}rocker_R_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
            <bullet>
              <friction>0.3</friction>
              <friction2>0.3</friction2>
              <rolling_friction>0.1</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>
    <!-- wheel ODE properties -->
    <gazebo reference="${link_prefix}wheel_FL_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>3</mu>
              <mu2>3</mu2>
              <slip1>0.001</slip1>
              <slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
            <bullet>
              <friction>2</friction>
              <friction2>2</friction2>
              <rolling_friction>0.01</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo reference="${link_prefix}wheel_FR_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>3</mu>
              <mu2>3</mu2>
              <slip1>0.001</slip1>
              <slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
            <bullet>
              <friction>2</friction>
              <friction2>2</friction2>
              <rolling_friction>0.01</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo reference="${link_prefix}wheel_RL_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>3</mu>
              <mu2>3</mu2>
              <slip1>0.001</slip1>
              <slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
            <bullet>
              <friction>2</friction>
              <friction2>2</friction2>
              <rolling_friction>0.01</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo reference="${link_prefix}wheel_RR_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>3</mu>
              <mu2>3</mu2>
              <slip1>0.001</slip1>
              <slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
            <bullet>
              <friction>2</friction>
              <friction2>2</friction2>
              <rolling_friction>0.01</rolling_friction>
            </bullet>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <!-- camera -->
    <gazebo reference="${link_prefix}camera_frame">
      <sensor name="camera" type="camera">
          <camera name="leo_camera">
              <horizontal_fov>1.9</horizontal_fov>
              <image>
                  <width>640</width>
                  <height>480</height>
                  <format>R8G8B8</format>
              </image>
              <clip>
                  <near>0.05</near>
                  <far>300</far>
              </clip>
              <noise>
                <type>gaussian</type>
                <mean>0.0</mean>
                <stddev>0.007</stddev>
              </noise>
              <distortion>
                <k1>-0.279817</k1>
                <k2>0.060321</k2>
                <k3>0.000487</k3>
                <p1>0.000310</p1>
                <p2>0.000000</p2>
                <center>0.5 0.5</center>
              </distortion>              
          </camera>
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <visualize>true</visualize>
          <topic>${link_prefix}camera/image_raw</topic>
          <gz_frame_id>${link_prefix}camera_optical_frame</gz_frame_id>
      </sensor>
    </gazebo>

    <!-- rocker differential -->
    <gazebo>
      <plugin name="leo_gz::DifferentialSystem" filename="libleo_gz_differential_plugin.so">
        <jointA>rocker_L_joint</jointA>
        <jointB>rocker_R_joint</jointB>
        <forceConstant>500.0</forceConstant>
      </plugin>
    </gazebo>

    <gazebo>
      <plugin
        filename="libgz-sim-joint-state-publisher-system.so"
        name="gz::sim::systems::JointStatePublisher">
        <topic>${link_prefix}joint_states</topic>
      </plugin>
    </gazebo>

    <gazebo reference="${link_prefix}imu_frame">
      <sensor type="imu" name="leo_imu_sensor">
        <update_rate>100</update_rate>
        <visualize>true</visualize>
        <topic>${link_prefix}imu/data_raw</topic>
        <always_on>1</always_on>
        <gz_frame_id>${link_prefix}imu_frame</gz_frame_id>
      </sensor>
    </gazebo>

    <!-- 2D LiDAR sensor for navigation -->
    <gazebo reference="${link_prefix}lidar_link">
      <sensor type="gpu_lidar" name="leo_lidar_sensor">
        <topic>${link_prefix}scan</topic>
        <gz_frame_id>${link_prefix}lidar_link</gz_frame_id>
        <update_rate>5.5</update_rate>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>12.0</max>
            <resolution>0.015</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
      </sensor>
    </gazebo>

    <!-- GPS (NavSat) sensor for outdoor navigation -->
    <gazebo reference="${link_prefix}base_link">
      <sensor type="navsat" name="leo_gps_sensor">
        <topic>${link_prefix}navsat</topic>
        <gz_frame_id>${link_prefix}base_link</gz_frame_id>
        <update_rate>5</update_rate>
        <always_on>1</always_on>
        <noise>
          <horizontal_position>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.5</stddev>
            </noise>
          </horizontal_position>
          <vertical_position>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.0</stddev>
            </noise>
          </vertical_position>
          <horizontal_velocity>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.1</stddev>
            </noise>
          </horizontal_velocity>
          <vertical_velocity>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.1</stddev>
            </noise>
          </vertical_velocity>
        </noise>
      </sensor>
    </gazebo>
    <gazebo>
    
      <plugin
        filename="libgz-sim-diff-drive-system.so"
        name="gz::sim::systems::DiffDrive">
        <left_joint>wheel_FL_joint</left_joint>
        <right_joint>wheel_FR_joint</right_joint>
        <left_joint>wheel_RL_joint</left_joint>
        <right_joint>wheel_RR_joint</right_joint>
        <wheel_separation>0.716</wheel_separation>
        <wheel_radius>0.125</wheel_radius>
        <frame_id>odom</frame_id>
        <child_frame_id>${link_prefix}base_footprint</child_frame_id>
        <odom_publish_frequency>20</odom_publish_frequency>
        <topic>${link_prefix}cmd_vel</topic>
        <odom_topic>${link_prefix}odom</odom_topic>
        <tf_topic>${link_prefix}tf</tf_topic>
        <max_linear_acceleration>10.0</max_linear_acceleration>
        <max_angular_acceleration>15.0</max_angular_acceleration>
        <min_linear_acceleration>-10.0</min_linear_acceleration>
        <min_angular_acceleration>-15.0</min_angular_acceleration>
      </plugin>
    </gazebo>
  </xacro:macro>

  <xacro:macro name="leo_sim" 
               params="default_antenna:=true 
                       fixed:=false
                       robot_ns:=''
                       mecanum_wheels:=false">

    <xacro:property name="link_prefix" value=""/>
    <xacro:if value="${robot_ns != '' and robot_ns != '/'}">
      <xacro:property name="link_prefix" value="${robot_ns}/"/>
    </xacro:if>

    <xacro:leo default_antenna="${default_antenna}"
               rockers_fixed="false"
               link_prefix="${link_prefix}"
               mecanum_wheels="${mecanum_wheels}"/>

    <xacro:leo_gazebo robot_ns="${robot_ns}"/>

    <xacro:if value="${fixed}">
      <link name="world"/>
      <joint name="fixed" type="fixed">
        <parent link="world"/>
        <child link="${link_prefix}base_footprint"/>
        <origin xyz="0 0 2"/>
      </joint>
    </xacro:if>
  
  </xacro:macro>

</robot>